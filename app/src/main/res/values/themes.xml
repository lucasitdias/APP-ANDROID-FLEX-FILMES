<?xml version="1.0" encoding="utf-8"?>
<!-- Seção: temas -->
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema principal -->
    <style name="Theme.FlexFilmes" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Cor primária -->
        <item name="colorPrimary">#000000</item>

        <!-- Variante primária -->
        <item name="colorPrimaryVariant">#000000</item>

        <!-- Cor sobre primária -->
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">#000000</item>

    </style>

    <!-- Estilo para o título da Toolbar usado em toolbar_flexfilmes.xml -->
    <style name="Toolbar.Title" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

</resources>
