<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Cabeçalho com logo + nome FlexFilmes centralizados -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <!-- Ícone da logo maior -->
        <ImageView
            android:id="@+id/app_logo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="Logo FlexFilmes"
        android:layout_marginEnd="12dp"/>

        <!-- Texto FlexFilmes já existente -->
        <TextView
            android:id="@+id/app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FlexFilmes"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>
    </LinearLayout>

    <!-- Cabeçalho do catálogo centralizado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/icon_catalog"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/icone_catalogo"
            android:contentDescription="Ícone catálogo"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/catalog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Catálogo de Filmes"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>
    </LinearLayout>

    <!-- Lista de filmes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_movies"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"/>
</LinearLayout>
