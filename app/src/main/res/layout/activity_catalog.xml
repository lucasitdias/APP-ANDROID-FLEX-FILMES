<?xml version="1.0" encoding="utf-8"?>
<!-- Caminho: app/src/main/res/layout/activity_catalog.xml -->
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- include toolbar padronizada -->
        <include
            layout="@layout/toolbar_flexfilmes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Conteúdo rolável do catálogo (começa abaixo da toolbar) -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="?attr/actionBarSize"
            android:fillViewport="true">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <!-- Continue assistindo -->
                <TextView
                    android:id="@+id/label_continue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continuar assistindo"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginTop="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_continue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"/>

                <!-- Minha lista (também usada para resultados de busca) -->
                <TextView
                    android:id="@+id/label_mylist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minha lista"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginTop="16dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_mylist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"/>

                <!-- Top picks -->
                <TextView
                    android:id="@+id/label_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Principais escolhas para você"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginTop="16dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_top"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"/>

                <!-- Recentes -->
                <TextView
                    android:id="@+id/label_recent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Adicionados recentemente"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginTop="16dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_recent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

    <!-- Navigation drawer: atributos mínimos necessários para funcionar corretamente -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/drawer_background"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/drawer_header"
        app:itemIconTint="@null" />

</androidx.drawerlayout.widget.DrawerLayout>
