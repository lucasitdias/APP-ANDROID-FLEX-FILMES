<?xml version="1.0" encoding="utf-8"?>
<!-- Caminho: app/src/main/res/layout/activity_movie_detail.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- include toolbar padronizada -->
    <include
        layout="@layout/toolbar_flexfilmes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- CONTEÚDO: usar NestedScrollView para compatibilidade com RecyclerView -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Poster -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="250dp">

                <ImageView
                    android:id="@+id/imgMovie"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Poster do filme" />

                <!-- Play overlay estilizado: fundo circular e sombra leve -->
                <ImageView
                    android:id="@+id/playOverlay"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:src="@drawable/play_overlay"
                    android:background="@drawable/play_overlay_bg"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Assistir trailer" />

            </FrameLayout>

            <!-- estrelas + info -->
            <LinearLayout
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/star1"
                    android:src="@drawable/star_empty"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="Avaliação 1 estrela" />

                <ImageView
                    android:id="@+id/star2"
                    android:src="@drawable/star_empty"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="Avaliação 2 estrelas" />

                <ImageView
                    android:id="@+id/star3"
                    android:src="@drawable/star_empty"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="Avaliação 3 estrelas" />

                <ImageView
                    android:id="@+id/star4"
                    android:src="@drawable/star_empty"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="Avaliação 4 estrelas" />

                <ImageView
                    android:id="@+id/star5"
                    android:src="@drawable/star_empty"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="Avaliação 5 estrelas" />

                <TextView
                    android:id="@+id/txtInfo"
                    android:textColor="@color/gray"
                    android:layout_marginStart="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- título -->
            <TextView
                android:id="@+id/txtTitle"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- descrição -->
            <TextView
                android:id="@+id/txtDescription"
                android:textColor="@color/white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- BOTÕES -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <Button
                    android:id="@+id/btnDownload"
                    android:text="Download"
                    android:textColor="@color/white"
                    android:backgroundTint="#444444"
                    android:layout_margin="6dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnShare"
                    android:text="Compartilhar"
                    android:textColor="@color/white"
                    android:backgroundTint="#444444"
                    android:layout_margin="6dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- MINHA LISTA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <Button
                    android:id="@+id/btnMyList"
                    android:text="+ Minha Lista"
                    android:textColor="@color/white"
                    android:backgroundTint="#444444"
                    android:layout_margin="6dp"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- recomendados -->
            <TextView
                android:text="Títulos semelhantes"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:padding="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- RecyclerView: desabilitar nested scrolling para funcionar bem dentro do NestedScrollView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_recommended"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
