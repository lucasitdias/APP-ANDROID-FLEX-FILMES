<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#000000">

        <!-- LADO ESQUERDO -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/icone_voltar"
            android:tint="@android:color/white"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="16dp"/>

        <!-- CENTRO -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_launcher_foreground"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:text="FlexFilmes"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- LADO DIREITO -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:orientation="horizontal"
            android:layout_marginEnd="16dp">

            <ImageView
                android:id="@+id/iconSearch"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search"
                android:tint="@android:color/white"
                android:layout_marginEnd="16dp"/>

            <ImageView
                android:id="@+id/iconMenu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_menu"
                android:tint="@android:color/white"/>

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>


    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Poster -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="250dp">

                <ImageView
                    android:id="@+id/imgMovie"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>

                <ImageView
                    android:id="@+id/playOverlay"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:src="@drawable/play_overlay"/>

            </FrameLayout>

            <!-- estrelas -->
            <LinearLayout
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView android:id="@+id/star1" android:src="@drawable/star_empty" android:layout_width="28dp" android:layout_height="28dp"/>
                <ImageView android:id="@+id/star2" android:src="@drawable/star_empty" android:layout_width="28dp" android:layout_height="28dp"/>
                <ImageView android:id="@+id/star3" android:src="@drawable/star_empty" android:layout_width="28dp" android:layout_height="28dp"/>
                <ImageView android:id="@+id/star4" android:src="@drawable/star_empty" android:layout_width="28dp" android:layout_height="28dp"/>
                <ImageView android:id="@+id/star5" android:src="@drawable/star_empty" android:layout_width="28dp" android:layout_height="28dp"/>

                <TextView
                    android:id="@+id/txtInfo"
                    android:textColor="@color/gray"
                    android:layout_marginStart="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- título -->
            <TextView
                android:id="@+id/txtTitle"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- descrição -->
            <TextView
                android:id="@+id/txtDescription"
                android:textColor="@color/white"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- BOTÕES -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <Button
                    android:id="@+id/btnDownload"
                    android:text="Download"
                    android:textColor="@color/white"
                    android:backgroundTint="#444444"
                    android:layout_margin="6dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnShare"
                    android:text="Compartilhar"
                    android:textColor="@color/white"
                    android:backgroundTint="#444444"
                    android:layout_margin="6dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- MINHA LISTA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <Button
                    android:id="@+id/btnMyList"
                    android:text="+ Minha Lista"
                    android:textColor="@color/white"
                    android:backgroundTint="#444444"
                    android:layout_margin="6dp"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- recomendados -->
            <TextView
                android:text="Títulos semelhantes"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:padding="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_recommended"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>